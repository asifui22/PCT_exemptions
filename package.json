{
  "name": "PCtExemptions",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.3.1",
    "@sap-cloud-sdk/resilience": "^4.3.1",
    "@sap/cds": "^9",
    "@sap/cds-mtxs": "^3",
    "@sap/xssec": "^4",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9.6.1",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.29"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-pctexemptionapp": "cds watch --open pctexemptionapp/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy PCtExemptions --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/pctexemptionapp"
  ],
  "cds": {
    "requires": {
      "[production]": {
        "db": "hana",
        "auth": "xsuaa",
        "multitenancy": true
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true,
      "spa_process_destination": {
        "kind": "rest",
        "credentials": {
          "destination": "spa_process_destination"
        }
      },
      "[with-mtx]": {
        "multitenancy": true
      },
      "PurchaseOrder_API": {
        "kind": "odata-v2",
        "model": "srv/external/PurchaseOrder_API"
      }
    },
    "profile": "with-mtx-sidecar"
  }
}