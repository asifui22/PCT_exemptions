{
  "_version": "1.76.0",
  "sap.app": {
    "id": "pctexemptionapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.0",
      "toolsId": "4a632b2e-5328-496e-96ed-c734b30e170a"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/pct/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "PCTExemptions-display": {
          "semanticObject": "PCTExemptions",
          "action": "display",
          "title": "{{PCTExemptions-display.flpTitle}}",
          "subTitle": "{{PCTExemptions-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.143.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "pctexemptionapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "flexibleColumnLayout": {
          "defaultTwoColumnLayoutType": "TwoColumnsMidExpanded",
          "defaultThreeColumnLayoutType": "ThreeColumnsEndExpanded"
        },
        "routerClass": "sap.f.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PCTExemptionsList",
          "target": [
            "PCTExemptionsList"
          ]
        },
        {
          "pattern": "PCTExemptions({key}):?query:",
          "name": "PCTExemptionsObjectPage",
          "target": [
            "PCTExemptionsList",
            "PCTExemptionsObjectPage"
          ]
        },
        {
          "name": "PurchaseOrderObjectPage",
          "pattern": "PurchaseOrder({PurchaseOrderKey}):?query:",
          "target": [
            "PCTExemptionsList",
            "PurchaseOrderObjectPage"
          ]
        }
      ],
      "targets": {
        "PCTExemptionsList": {
          "type": "Component",
          "id": "PCTExemptionsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PCTExemptions",
              "variantManagement": "Page",
              "navigation": {
                "PCTExemptions": {
                  "detail": {
                    "route": "PCTExemptionsObjectPage"
                  }
                },
                "PurchaseOrder": {
                  "detail": {
                    "route": "PurchaseOrderObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "condensedTableLayout": true,
                    "disableCopyToClipboard": true,
                    "selectAll": true
                  }
                }
              },
              "initialLoad": "Enabled",
              "views": {
                "paths": [
                  {
                    "key": "tableView",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView"
                  },
                  {
                    "key": "tableView1",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView",
                    "entitySet": "PurchaseOrder"
                  }
                ],
                "showCounts": true
              }
            }
          },
          "controlAggregation": "beginColumnPages",
          "contextPattern": ""
        },
        "PCTExemptionsObjectPage": {
          "type": "Component",
          "id": "PCTExemptionsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PCTExemptions",
              "content": {
                "header": {
                  "anchorBarVisible": true
                }
              }
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/PCTExemptions({key})"
        },
        "PurchaseOrderObjectPage": {
          "type": "Component",
          "id": "PurchaseOrderObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/PurchaseOrder",
              "content": {
                "header": {
                  "anchorBarVisible": true
                }
              },
              "editableHeaderContent": false
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/PurchaseOrder({PurchaseOrderKey})"
        }
      }
    },
    "rootView": {
      "viewName": "sap.fe.templates.RootContainer.view.Fcl",
      "type": "XML",
      "async": true,
      "id": "appRootView"
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.cloud": {
    "public": true,
    "service": "PCtExemptions.service"
  }
}
